<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Home</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-dark d-flex justify-content-center align-items-center vh-100">

<div class="card shadow-lg border-0 rounded-4 text-center p-5" style="max-width:500px; width:100%;">
    <h1 class="display-6 fw-bold text-primary">🏠 Welcome</h1>

    <p class="text-muted mt-3">
        Google OAuth Authentication Demo
    </p>

    <% if(user){ %>

        <a href="/profile" class="btn btn-success btn-lg rounded-pill mt-3">
            View Profile
        </a>

    <% } else { %>

        <a href="/auth/login" class="btn btn-primary btn-lg rounded-pill mt-3">
            Login
        </a>

    <% } %>

</div>

</body>
</html>